{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "outDir": "bin",
    "rootDir": "bin"
  },
  "include": ["bin/*.ts"],
  "exclude": ["bin/*.js"]
}
